# ArticleHub — copy to .env (never commit .env)

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# New keys (recommended) OR legacy JWT keys
# Publishable = low privilege (old anon)
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret = server only, full access (old service_role) — required for admin/register
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_...

PORT=5000
NODE_ENV=production

# Seeded admin account (privileged)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@articlehub.local

# Sign JWTs (use a long random string in production)
JWT_SECRET=replace-with-long-random-secret
