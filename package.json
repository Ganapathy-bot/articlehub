{
  "name": "articlehub",
  "version": "1.0.0",
  "private": true,
  "description": "ArticleHub — articles & PDFs with Supabase, user registration, and admin privileges",
  "proxy": "http://localhost:5000",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.4.0",
    "@supabase/supabase-js": "^2.49.1",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-redux": "^7.2.2",
    "react-router-dom": "^5.2.0",
    "react-scripts": "3.4.1"
  },
  "scripts": {
    "prestart:client": "node scripts/create-sample-pdfs.js && node scripts/sync-pdfs.js",
    "start:client": "set \"NODE_OPTIONS=--openssl-legacy-provider\" && set \"BROWSER=none\" && react-scripts start",
    "prebuild": "node scripts/create-sample-pdfs.js && node scripts/sync-pdfs.js",
    "build": "node scripts/build-production.js",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "seed": "node server/index.js",
    "heroku-postbuild": "npm run build",
    "test": "react-scripts test",
    "test:secrets": "node scripts/check-no-hardcoded-credentials.js",
    "eject": "react-scripts eject",
    "pdfs": "node scripts/create-sample-pdfs.js",
    "sync": "node scripts/sync-pdfs.js"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
